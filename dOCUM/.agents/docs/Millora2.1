class MunicipiLifecycle(Base):
    __tablename__ = "municipis_lifecycle"
    
    # IDENTITAT
    id = Column(Integer, primary_key=True)
    nom = Column(String(100), nullable=False, index=True)
    comarca = Column(String(50))
    poblacio = Column(Integer)
    geografia = Column(Enum('muntanya', 'mar', 'interior', 'city', name='geografia'))
    
    # DIAGNÒSTIC
    diagnostic_digital = Column(JSONB)  # app_propia, google_maps_pois, wikiloc_rutes, buit_digital
    patrimoni = Column(JSONB)  # POIs, BICs, rutes
    context_politic = Column(JSONB)  # projectes, subvencions, eleccions
    angle_personalitzacio = Column(Text)
    
    # FUNNEL
    etapa_actual = Column(Enum(
        'research', 'contacte', 'demo_pendent', 'demo_ok',
        'oferta', 'documentacio', 'aprovacio', 'contracte',
        'client', 'pausa', 'perdut',
        name='etapa_funnel'
    ), default='research', index=True)
    
    historial_etapes = Column(JSONB)  # [{etapa, data_inici, data_fi, notes}]
    blocker_actual = Column(Enum('alcalde', 'tecnic', 'cfo', 'temporitzacio', 'cap', name='blocker'))
    temperatura = Column(Enum('fred', 'templat', 'calent', 'bullent', name='temperatura'), default='fred')
    dies_etapa_actual = Column(Integer, default=0)
    
    # POST-CONVERSIÓ (només per arxiu, no gestió)
    data_conversio = Column(DateTime, nullable=True)
    pla_contractat = Column(Enum('Roure', 'Mirador', 'Territori', name='pla'), nullable=True)
    estat_final = Column(Enum('client', 'perdut', 'pausa', name='estat_final'), nullable=True)
    
    # RELACIONS
    actor_principal_id = Column(Integer, ForeignKey("contactes.id"), nullable=True)
    contactes = relationship("Contacte", back_populates="municipi")
    emails = relationship("Email", back_populates="municipi")
    trucades = relationship("Trucada", back_populates="municipi")
    reunions = relationship("Reunio", back_populates="municipi")
    email_drafts = relationship("EmailDraft", back_populates="municipi")
    sequencia_emails = relationship("EmailSequencia", order_by="EmailSequencia.numero_email")
    
    # METADADES
    data_creacio = Column(DateTime, default=datetime.utcnow)
    data_ultima_accio = Column(DateTime)
