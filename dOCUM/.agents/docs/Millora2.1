## 5. MIGRACIÓ DES DE V1.0

```python
# migrate_to_v2.py

def migrar_municipi(municipi_v1: dict) -> MunicipiLifecycle:
    """
    Mapeig de v1 a v2
    """
    return MunicipiLifecycle(
        nom=municipi_v1['nom'],
        comarca=municipi_v1.get('comarca'),
        poblacio=municipi_v1.get('poblacio'),
        geografia=detectar_geografia(municipi_v1.get('descripcio', '')),
        
        diagnostic_digital={
            'app_propia': municipi_v1.get('te_app', False),
            'google_maps_pois': municipi_v1.get('pois_gmaps', 0),
            'wikiloc_rutes': municipi_v1.get('rutes_wikiloc', 0),
            'buit_digital': municipi_v1.get('observacions', '')
        },
        
        etapa_actual=mapear_etapa(municipi_v1.get('estat', 'nou')),
        data_creacio=municipi_v1.get('data_alta', datetime.utcnow())
    )

def mapear_etapa(etapa_v1: str) -> str:
    mapping = {
        'nou': 'research',
        'contactat': 'contacte',
        'interessat': 'demo_pendent',
        'reunio_feta': 'demo_ok',
        'proposta_enviada': 'oferta',
        'negociacio': 'documentacio',
        'aprovacio': 'aprovacio',
        'contracte': 'contracte',
        'client': 'client',
        'perdut': 'perdut',
        'congelat': 'pausa'
    }
    return mapping.get(etapa_v1, 'research')

def run_migration():
    db_v2 = next(get_db_v2())
    db_v1 = next(get_db_v1())
    
    # 1. Migrar municipis
    for m_v1 in db_v1.query(MunicipiV1).all():
        m_v2 = migrar_municipi(m_v1.__dict__)
        db_v2.add(m_v2)
        db_v2.flush()  # Per obtenir ID
        
        # 2. Migrar contactes a taula relacional
        for c_v1 in m_v1.contactes:
            contacte = Contacte(
                municipi_id=m_v2.id,
                nom=c_v1['nom'],
                carrec=c_v1.get('carrec', 'altre'),
                email=c_v1.get('email'),
                telefon=c_v1.get('telefon'),
                actiu=True,
                principal=c_v1.get('principal', False)
            )
            db_v2.add(contacte)
        
        # 3. Marcar actor principal
        principal = db_v2.query(Contacte).filter_by(
            municipi_id=m_v2.id, 
            principal=True
        ).first()
        if principal:
            m_v2.actor_principal_id = principal.id
    
    db_v2.commit()
    print(f"Migrats {db_v2.query(MunicipiLifecycle).count()} municipis")

if __name__ == "__main__":
    run_migration()
```

