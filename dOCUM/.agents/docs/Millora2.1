        paraules = extreure_paraules_clau(text)
        
        # Actualitzar llenguatge preferit
        memoria.llenguatge_preferit = list(set(
            (memoria.llenguatge_preferit or []) + paraules
        ))[:10]  # Màxim 10
        
        # Actualitzar moment òptim
        hora = dades.get('hora_resposta')
        if hora:
            memoria.moment_optimal = actualitzar_moment_optimal(
                memoria.moment_optimal, hora
            )
    
    elif tipus == 'demo_realitzada':
        if dades.get('poi_mes_reaccio'):
            memoria.ganxos_exitosos = (memoria.ganxos_exitosos or []) + [dades['poi_mes_reaccio']]
            memoria.ganxos_exitosos = memoria.ganxos_exitosos[-5:]  # Últims 5
        
        if dades.get('angle_fallit'):
            memoria.angles_fallits = (memoria.angles_fallits or []) + [dades['angle_fallit']]
            memoria.angles_fallits = memoria.angles_fallits[-3:]
    
    elif tipus == 'blocker_resolt':
        memoria.blockers_resolts = (memoria.blockers_resolts or []) + [{
            'tipus': dades['blocker'],
            'estrategia': dades['com'],
            'data': datetime.utcnow().isoformat()
        }]
    
    memoria.data_actualitzacio = datetime.utcnow()
    db_session.commit()

def trobar_patro_similar(municipi: MunicipiLifecycle, db_session) -> Optional[PatroMunicipi]:
    rang = 'petit' if (municipi.poblacio or 0) < 5000 else 'mitja' if (municipi.poblacio or 0) < 20000 else 'gran'
    
    return db_session.query(PatroMunicipi).filter_by(
        rang_poblacio=rang,
        tipus_geografia=municipi.geografia,
        context_politic=municipi.context_politic.get('tipus', 'majoria') if municipi.context_politic else 'majoria'
    ).first()
