# services/sequenciador.py

def generar_sequencia_prospeccio(municipi_id: int, db_session) -> List[EmailSequencia]:
    municipi = db_session.query(MunicipiLifecycle).get(municipi_id)
    dia0 = datetime.utcnow()
    
    seq = []
    
    # EMAIL 1: Disparador patrimoni (generar immediatament)
    draft1 = generar_draft(
        municipi=municipi,
        tipus='email_1_prospeccio',
        contacte=get_contacte_principal(municipi, 'alcalde')
    )
    
    seq.append(EmailSequencia(
        municipi_id=municipi_id,
        numero_email=1,
        tipus_sequencia='prospeccio',
        estat='preparat',
        data_programada=dia0,
        draft_id=draft1.id
    ))
    
    # EMAIL 2: Dolor (programat, draft es genera dinàmicament quan toqui)
    seq.append(EmailSequencia(
        municipi_id=municipi_id,
        numero_email=2,
        tipus_sequencia='prospeccio',
        estat='pendent',
        data_programada=dia0 + timedelta(days=4)
    ))
    
    # EMAIL 3: FOMO veí
    seq.append(EmailSequencia(
        municipi_id=municipi_id,
        numero_email=3,
        tipus_sequencia='prospeccio',
        estat='pendent',
        data_programada=dia0 + timedelta(days=8)
    ))
    
    # EMAIL 4: Tancament suau
    seq.append(EmailSequencia(
        municipi_id=municipi_id,
        numero_email=4,
        tipus_sequencia='recuperacio',
        estat='pendent',
        data_programada=dia0 + timedelta(days=14)
    ))
    
    db_session.add_all(seq)
    db_session.commit()
    
    return seq

def actualitzar_sequencia_segons_event(municipi_id: int, email_num: int, event: str, db_session):
    seq = db_session.query(EmailSequencia).filter_by(
        municipi_id=municipi_id
    ).order_by(EmailSequencia.numero_email).all()
    
    email_actual = seq[email_num - 1]
    
    if event == 'resposta_positiva':
        email_actual.estat = 'respost'
        email_actual.seguent_accio = 'trucada_rapida'
        
        # Cancel·lar resta prospecció
        for e in seq[email_num:]:
            if e.tipus_sequencia == 'prospeccio':
                e.estat = 'cancelat'
        
        # Afegir seguiment immediat
        municipi = db_session.query(MunicipiLifecycle).get(municipi_id)
        draft = generar_draft(municipi, 'seguiment_urgent')
        
        nou = EmailSequencia(
            municipi_id=municipi_id,
            numero_email=len(seq) + 1,
            tipus_sequencia='seguiment',
            estat='preparat',
            data_programada=datetime.utcnow() + timedelta(hours=2),
            draft_id=draft.id
        )
        db_session.add(nou)
        
    elif event == 'obert_no_resposta':
        email_actual.estat = 'obert'
        # Deixar següent programat
        
    elif event == 'no_obert':
        email_actual.estat = 'no_obert'
        # Accelerar següent
        if email_num < len(seq):
            seq[email_num].data_programada -= timedelta(days=1)
    
    db_session.commit()

def preparar_email_sequencia(municipi_id: int, numero_email: int, db_session):
    seq = db_session.query(EmailSequencia).filter_by(
        municipi_id=municipi_id,
        numero_email=numero_email
    ).first()
    
    if seq.estat != 'pendent':
        return  # Ja preparat o enviat
    
    municipi = db_session.query(MunicipiLifecycle).get(municipi_id)
    
    # Determinar tipus segons context
    if numero_email == 2:
        ultim = get_ultim_email(municipi)
        if ultim and ultim.obert:
            tipus = 'email_2_interes' if ultim.cops_obert > 2 else 'email_2_suau'
        else:
            tipus = 'email_2_subject_alt'
    elif numero_email == 3:
        tipus = 'email_3_fomo_vei'
    elif numero_email == 4:
        tipus = 'email_4_tancament'
    else:
        tipus = 'nurture'
    
    contacte = get_contacte_principal(municipi, 'alcalde')
    draft = generar_draft(municipi, tipus, contacte)
    
    seq.draft_id = draft.id
    seq.estat = 'preparat'
    db_session.commit()
    
    return draft
