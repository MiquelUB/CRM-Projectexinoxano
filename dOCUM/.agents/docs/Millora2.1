# services/prioritizer.py

def calcular_prioritat(municipi: MunicipiLifecycle) -> int:
    score = 0
    
    # Urgència temporal
    urgencia = {
        'documentacio': (5, 100),
        'aprovacio': (14, 90),
        'demo_ok': (2, 80),
        'oferta': (7, 70),
        'demo_pendent': (5, 60),
        'contacte': (7, 50),
    }
    
    if municipi.etapa_actual in urgencia:
        max_dies, punts = urgencia[municipi.etapa_actual]
        if municipi.dies_etapa_actual > max_dies:
            score += punts + (municipi.dies_etapa_actual - max_dies) * 5
        elif municipi.dies_etapa_actual > max_dies * 0.5:
            score += punts * 0.7
    
    # Refredament
    dies_ultim = (datetime.utcnow() - municipi.data_ultima_accio).days if municipi.data_ultima_accio else 999
    if dies_ultim > 7:
        score += 80
    elif dies_ultim > 3:
        score += 40
    
    # Valor deal
    if municipi.pla_contractat == 'Territori':
        score += 50
    if municipi.poblacio and municipi.poblacio > 10000:
        score += 40
    
    return int(score)

def generar_dashboard_diari(db_session) -> Dict:
    municipis_actius = db_session.query(MunicipiLifecycle).filter(
        MunicipiLifecycle.etapa_actual.notin_(['client', 'perdut', 'pausa'])
    ).all()
    
    puntuats = [(m, calcular_prioritat(m)) for m in municipis_actius]
    puntuats.sort(key=lambda x: x[1], reverse=True)
    
    accions = []
    for i, (municipi, score) in enumerate(puntuats[:3], 1):
        accio = determinar_accio(municipi)
        accions.append({
            'ordre': i,
            'prioritat': 'critica' if score > 80 else 'alta' if score > 50 else 'media',
            'municipi_id': municipi.id,
            'municipi_nom': municipi.nom,
            'etapa': municipi.etapa_actual,
            'blocker': municipi.blocker_actual,
            'dies_etapa': municipi.dies_etapa_actual,
            'tipus_accio': accio['tipus'],
            'titol': accio['titol'],
            'descripcio': accio['descripcio'],
            'executable': accio['executable'],
            'dades_execucio': accio.get('dades_execucio', {}),
            'contacte_sugerit_id': accio.get('contacte_id'),
            'subject_sugerit': accio.get('subject'),
            'cos_esborrany': accio.get('cos'),
            'guio_trucada': accio.get('guio'),
            'pla_b': accio.get('pla_b'),
            'score': score
        })
    
    return {
        'data': datetime.utcnow().isoformat(),
        'accions_prioritaries': accions,
        'preparar_si_sobra': generar_llista_preparacio(puntuats[3:]) if len(puntuats) > 3 else []
    }
