def determinar_accio(municipi: MunicipiLifecycle) -> Dict:
    etapa = municipi.etapa_actual
    blocker = municipi.blocker_actual
    dies = municipi.dies_etapa_actual
    
    # CONTACTE
    if etapa == 'contacte':
        ultim_email = get_ultim_email(municipi)
        
        if not ultim_email:
            contacte = get_contacte_principal(municipi, 'alcalde')
            return {
                'tipus': 'email',
                'executable': True,
                'titol': f'Preparar email inicial a {contacte.nom if contacte else "Alcalde"}',
                'descripcio': 'Angle patrimoni específic, zero enllaços',
                'dades_execucio': {
                    'obre_editor': True,
                    'contacte_id': contacte.id if contacte else None,
                    'tipus_email': 'email_1_prospeccio'
                },
                'pla_b': 'Esperar 2 dies, revisar si obert'
            }
        
        if ultim_email.respost:
            return {
                'tipus': 'trucada',
                'executable': True,
                'titol': 'Trucada de seguiment urgent',
                'descripcio': 'Respondre dubtes, proposar demo curta',
                'dades_execucio': {
                    'obre_formulari_trucada': True,
                    'contacte_id': ultim_email.contacte_id,
                    'urgencia': 'alta'
                },
                'guio': 'Hola, he vist el teu email...',
                'pla_b': 'Email proposant hora concreta'
            }
        
        if ultim_email.obert and not ultim_email.respost:
            if ultim_email.cops_obert > 2:
                return {
                    'tipus': 'email',
                    'executable': True,
                    'titol': 'Email 2: El micròfon apagat',
                    'descripcio': 'Angle dolor, FOMO suau',
                    'dades_execucio': {
                        'obre_editor': True,
                        'tipus_email': 'email_2_dolor'
                    },
                    'pla_b': 'Trucada dia 5 si no resposta'
                }
            else:
                return {
                    'tipus': 'esperar',
                    'executable': False,
                    'titol': 'Esperar més engagement',
                    'descripcio': f'Email obert {ultim_email.cops_obert} cops, poc engagement',
                    'pla_b': f'Email 2 preparat per enviar dia {dies + 2}'
                }
        
        if not ultim_email.obert and dies > 3:
            return {
                'tipus': 'email',
                'executable': True,
                'titol': 'Email 2: Subject alternatiu',
                'descripcio': 'Mateix angle, subject diferent',
                'dades_execucio': {
                    'obre_editor': True,
                    'tipus_email': 'email_2_subject_alt'
                },
                'pla_b': 'Trucada al tècnic (no alcalde) dia 5'
            }
    
    # DEMO_PENDENT
    if etapa == 'demo_pendent':
        return {
            'tipus': 'preparar_demo',
            'executable': True,
            'titol': 'Confirmar i preparar demo',
            'descripcio': 'Verificar assistents, preparar contingut específic',
            'dades_execucio': {
                'obre_checklist': True,
                'accions': ['Confirmar hora', 'Verificar POIs', 'Preparar Time Slider']
            },
            'pla_b': 'Reprogramar si no confirmen 24h abans'
        }
    
    # DEMO_OK
    if etapa == 'demo_ok':
        if dies > 2:
            return {
                'tipus': 'email',
                'executable': True,
                'titol': 'Seguiment post-demo',
                'descripcio': 'Referenciar moment concret de la demo',
                'dades_execucio': {
                    'obre_editor': True,
                    'tipus_email': 'seguiment_post_demo'
                },
                'pla_b': 'Trucada si no obert en 24h'
            }
        else:
            return {
                'tipus': 'completar_aar',
                'executable': True,
                'titol': 'Completar After Action Review',
                'descripcio': 'Omplir notes de la reunió mentre és fresca',
                'dades_execucio': {
                    'obre_formulari_aar': True
                },
                'pla_b': None
            }
    
    # OFERTA
    if etapa == 'oferta':
        if blocker == 'cfo':
            contacte = get_contacte_principal(municipi, 'cfo')
            return {
                'tipus': 'email',
                'executable': True,
                'titol': 'Documentació compliance a CFO',
                'descripcio': 'RGPD, servidors UE, protocol offboarding',
