### 2.5 Draft Generator Service (IA)

```python
# services/draft_generator.py

def generar_draft(municipi: MunicipiLifecycle, tipus: str, contacte: Contacte = None) -> EmailDraft:
    # Seleccionar prompt segons tipus i actor
    actor = detectar_actor(tipus, contacte)
    prompt_base = get_prompt_base()
    prompt_actor = get_prompt_actor(actor)
    prompt_situacio = get_prompt_situacio(tipus)
    
    # Construir context complet
    context = {
        'municipi': municipi.nom,
        'poblacio': municipi.poblacio,
        'patrimoni': (municipi.patrimoni or {}).get('pois_principals', [])[:2],
        'angle': municipi.angle_personalitzacio,
        'contacte': contacte.nom if contacte else 'Alcalde',
        'carrec': contacte.carrec if contacte else 'alcalde',
        'to': contacte.to_preferit if contacte else 'proxim',
        'historia': get_historia_email(municipi, limit=3)
    }
    
    # Cridar IA (OpenRouter)
    variants = []
    for i in range(3):
        resposta = cridar_ia(
            prompt_base + prompt_actor + prompt_situacio,
            context,
            temperatura=0.7 + (i * 0.1)  # Varietat
        )
        variants.append({
            'subject': resposta['subject'],
            'cos': resposta['cos'],
            'angle': resposta.get('angle', 'general'),
            'score': resposta.get('score', 0.8)
        })
    
    # Seleccionar millor variant inicial
    millor = max(variants, key=lambda x: x['score'])
    
    draft = EmailDraft(
        municipi_id=municipi.id,
        contacte_id=contacte.id if contacte else None,
        estat='esborrany',
        subject=millor['subject'],
        cos=millor['cos'],
        generat_per_ia=True,
        prompt_utilitzat=f"{prompt_base}\n{prompt_actor}\n{prompt_situacio}",
        variants_generades=variants,
        variant_seleccionada=0
    )
    
    return draft

def get_prompt_actor(actor: str) -> str:
    prompts = {
        'alcalde': """
        Actor: Alcalde (Visionari). Vol llegat, visibilitat, guanyar eleccions.
        Missatge: sobirania digital, control del relat, "el teu municipi al mapa".
        Mai funcionalitats tècniques. Sempre impacte polític i territorial.
        To: proximitat, "tu", company de trinxera.
        """,
        'tecnic': """
        Actor: Tècnic de Turisme (Gatekeeper). Abrumado, por a obsolescència.
        Missatge: IA Punt d'Or estalvia temps, pàgina en blanc, autonomia.
        To: empatia, "sé que tens masses projectes", alleujament.
        """,
        'cfo': """
        Actor: CFO/Interventor (Blocker). Busca dir NO de forma segura.
        Missatge: contracte menor LCSP, RGPD, servidors UE, offboarding ZIP.
        To: formal, legal, sense ornaments, risc zero.
        """
    }
    return prompts.get(actor, prompts['alcalde'])

def get_prompt_situacio(tipus: str) -> str:
    prompts = {
        'email_1_prospeccio': """
        Situació: Primer contacte. Ganxo patrimoni específic.
        Regles: Màxim 120 paraules. Zero enllaços. Zero emojis.
        Estructura: Ganxo personalitzat → Dolor sutil → CTA binari.
        """,
        'email_2_dolor': """
        Situació: No resposta a email 1. Angle "micròfon apagat".
        Regles: Màxim 120 paraules. Zero enllaços.
        Estructura: Constatar silenci → Articular dolor → FOMO suau → CTA.
        """,
        'email_2_interes': """
        Situació: Obert múltiples cops, no resposta. Interès latent.
        Regles: Màxim 120 paraules.
        Estructura: Notar interès → Ofrir ajuda → Proposar trucada curta.
        """,
        'seguiment_post_demo': """
        Situació: Demo realitzada, cal mantenir calor.
        Regles: Referenciar moment concret de la demo.
        Estructura: Recordar moment clau → Proposar següent pas → CTA temporal.
        """,
        'compliance_cfo': """
        Situació: Blocker legal, necessita seguretat.
        Regles: Documentació adjunta esmentada, no tot al cos.
        Estructura: Reconèixer preocupació → Llistar garanties → Ofrir trucada tècnica.
        """
    }
    return prompts.get(tipus, prompts['email_1_prospeccio'])
