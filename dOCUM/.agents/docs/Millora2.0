MUNICIPIS_LIFECYCLE
├── id (PK)
├── nom, comarca, poblacio, geografia
├── diagnostic_digital (JSONB) - digital, patrimoni, context
├── angle_personalitzacio (Text)
├── etapa_actual (Enum 11 valors)
├── historial_etapes (JSONB)
├── blocker_actual (Enum)
├── temperatura (Enum)
├── dies_etapa_actual (Int)
├── data_conversio (DateTime, nullable)  # Només si 'client'
├── pla_contractat (Enum, nullable)       # Només si 'client'
├── estat_final (Enum, nullable)          # 'client' | 'perdut' | 'pausa'
├── actor_principal_id (FK → contactes.id, nullable)
└── data_creacio, data_ultima_accio

CONTACTES
├── id (PK)
├── municipi_id (FK)
├── nom, carrec (Enum), email, telefon
├── actiu (Bool), principal (Bool)
├── angles_exitosos (JSONB)
├── angles_fallits (JSONB)
├── moment_optimal (String)
├── to_preferit (Enum)
└── data_creacio

EMAILS, TRUCADES, REUNIONS  # Igual que abans

MEMORIA_MUNICIPI  # Igual que abans (però sense post-venda)

PATRO_MUNICIPI    # Igual que abans
